<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ app_name }}</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ============================================================
   ASCII-BRUTALIST DESIGN SYSTEM
   Bloomberg terminal x luxury tech brand
   Dense. Sharp. Tasteful.
   ============================================================ */
:root {
  --bg: #080d12;
  --surface: #0c1117;
  --raised: #10161d;
  --border: #1a2530;
  --border-hi: #2a3a4a;
  --cyan: #00d4ff;
  --blue: #0099cc;
  --text: #b8ccd8;
  --bright: #e8f0f4;
  --dim: #3a4f5f;
  --faint: #1e2d38;
  --green: #00e676;
  --red: #ff4757;
  --amber: #ffa726;
  --font: 'JetBrains Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  /* Subtle noise texture via SVG data URI */
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.02'/%3E%3C/svg%3E");
  color: var(--text);
  font-family: var(--font);
  font-size: 12px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

::selection { background: rgba(0,212,255,0.25); color: var(--bright); }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--dim); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--blue); }

/* ---- LAYOUT ---- */
.app { display: grid; grid-template-columns: 200px 1fr; min-height: 100vh; }

/* ---- SIDEBAR ---- */
.side {
  background: var(--surface);
  border-right: 1px solid var(--border);
  padding: 16px 14px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.brand {
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.brand-mark {
  font-size: 24px;
  font-weight: 800;
  color: var(--cyan);
  letter-spacing: -1px;
  line-height: 1;
  text-shadow: 0 0 20px rgba(0,212,255,0.3), 0 0 40px rgba(0,212,255,0.1);
  animation: pulse-glow 4s ease-in-out infinite;
}
@keyframes pulse-glow {
  0%, 100% { text-shadow: 0 0 20px rgba(0,212,255,0.3), 0 0 40px rgba(0,212,255,0.1); }
  50% { text-shadow: 0 0 24px rgba(0,212,255,0.5), 0 0 48px rgba(0,212,255,0.15); }
}
.brand-name { font-size: 9px; color: var(--dim); letter-spacing: 0.15em; text-transform: uppercase; line-height: 1.3; }
.brand-name b { color: var(--text); font-weight: 600; display: block; font-size: 10px; }

/* Upload */
.drop {
  border: 1px solid var(--border);
  padding: 10px;
  text-align: center;
  cursor: pointer;
  position: relative;
  transition: border-color 0.15s, background 0.15s;
}
.drop:hover { border-color: var(--cyan); background: rgba(0,212,255,0.02); }
.drop.loaded { border-color: var(--green); }
.drop input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
.drop-icon { color: var(--dim); font-size: 14px; }
.drop-text { color: var(--dim); font-size: 10px; margin-top: 2px; }
.drop-file { color: var(--green); font-size: 10px; word-break: break-all; }

/* Mode */
.mode-label { font-size: 9px; color: var(--dim); letter-spacing: 0.15em; text-transform: uppercase; }
.mode-row { display: flex; }
.mode-btn {
  flex: 1;
  padding: 7px 4px;
  font-family: var(--font);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: center;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--dim);
  cursor: pointer;
  transition: all 0.15s;
}
.mode-btn + .mode-btn { border-left: none; }
.mode-btn:hover { color: var(--text); background: var(--raised); }
.mode-btn.on {
  color: var(--bright);
  background: var(--blue);
  border-color: var(--blue);
}

.spacer { flex: 1; }

/* Sidebar buttons */
.side-actions { display: flex; gap: 6px; }
.s-btn {
  flex: 1;
  font-family: var(--font);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 8px;
  border: 1px solid var(--border);
  background: transparent;
  color: var(--cyan);
  cursor: pointer;
  transition: all 0.15s;
  text-align: center;
}
.s-btn:hover { background: var(--raised); border-color: var(--cyan); }
.s-btn.pri { background: rgba(0,153,204,0.12); }

/* ---- MAIN ---- */
.main { padding: 16px 20px; overflow-y: auto; }

/* Header */
.head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 14px;
}
.head-title { font-size: 11px; font-weight: 300; letter-spacing: 0.15em; text-transform: uppercase; color: var(--dim); }
.head-meta { display: flex; gap: 12px; font-size: 11px; }
.tag { color: var(--dim); }
.tag::before { content: "["; color: var(--faint); }
.tag::after { content: "]"; color: var(--faint); }
.tag.hi { color: var(--cyan); font-weight: 600; }

/* ---- METRIC GRID ---- */
.grid-9 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 14px;
}
.m-card {
  background: var(--surface);
  padding: 10px 12px 10px 14px;
  position: relative;
  overflow: hidden;
  cursor: default;
  transition: background 0.2s, box-shadow 0.2s;
  border-left: 2px solid transparent;
}
.m-card:hover {
  background: var(--raised);
  border-left-color: var(--cyan);
  box-shadow: inset 0 0 30px rgba(0,212,255,0.02);
}
.m-card:nth-child(3n+1):hover { border-left-color: var(--cyan); }
.m-card:nth-child(3n+2):hover { border-left-color: var(--blue); }
.m-card:nth-child(3n+3):hover { border-left-color: var(--green); }
.m-label { font-size: 9px; color: var(--dim); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 400; }
.m-val {
  font-size: 24px;
  font-weight: 700;
  color: var(--bright);
  margin-top: 2px;
  line-height: 1;
  letter-spacing: -0.5px;
}
.m-val .unit { font-size: 13px; font-weight: 400; color: var(--dim); margin-left: 1px; }
.m-spark-svg {
  position: absolute;
  bottom: 6px;
  right: 8px;
  opacity: 0.3;
  transition: opacity 0.25s;
}
.m-card:hover .m-spark-svg { opacity: 0.8; }
.m-tooltip {
  display: none;
  position: absolute;
  top: -28px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--raised);
  border: 1px solid var(--border-hi);
  padding: 3px 8px;
  font-size: 9px;
  color: var(--cyan);
  white-space: nowrap;
  pointer-events: none;
  z-index: 10;
}
.m-card:hover .m-tooltip { display: block; }

/* ---- SECTION DIVIDER ---- */
.inquiry {
  font-size: 10px;
  font-weight: 300;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--dim);
  padding: 8px 0;
  margin-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

/* ---- WIDGETS ---- */
.w {
  border: 1px solid var(--border);
  margin-bottom: 6px;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.w:hover { border-color: var(--border-hi); }
.w.active { border-color: var(--blue); box-shadow: 0 0 0 1px rgba(0,153,204,0.1); }
.w-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  cursor: pointer;
  user-select: none;
  transition: background 0.15s;
}
.w-head:hover { background: var(--raised); }
.w-head:active { background: rgba(0,212,255,0.04); }
.w-title { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text); }
.w-title .dot { display: inline-block; width: 6px; height: 6px; margin-right: 8px; background: var(--cyan); }
.w-title .dot.warn { background: var(--amber); }
.w-title .dot.bad { background: var(--red); }
.w-badge { font-size: 10px; color: var(--dim); font-weight: 400; transition: color 0.15s; }
.w:hover .w-badge { color: var(--text); }
.w-mini { display: inline-flex; gap: 3px; margin-left: 8px; align-items: flex-end; height: 12px; }
.w-mini-bar { width: 2px; background: var(--cyan); opacity: 0.4; min-height: 1px; transition: opacity 0.2s; }
.w:hover .w-mini-bar { opacity: 0.7; }
.w-arrow { color: var(--dim); font-size: 10px; margin-left: 8px; transition: transform 0.2s; display: inline-block; }
.w-head.open .w-arrow { transform: rotate(90deg); }

.w-body {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.25s ease;
}
.w-body.open { grid-template-rows: 1fr; }
.w-inner {
  overflow: hidden;
  padding: 0 12px;
  transition: padding 0.25s ease;
}
.w-body.open .w-inner { padding: 10px 12px 14px; border-top: 1px solid var(--border); }

/* ---- TABLES ---- */
.tbl { width: 100%; border-collapse: collapse; }
.tbl th {
  text-align: left;
  font-size: 9px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--dim);
  padding: 5px 8px;
  border-bottom: 1px solid var(--border);
}
.tbl td { padding: 4px 8px; border-bottom: 1px solid var(--faint); font-size: 11px; }
.tbl tr:hover td { background: rgba(0,212,255,0.02); }
.tbl .r { text-align: right; }
.tbl .accent { color: var(--cyan); font-weight: 600; }
.tbl .warn-text { color: var(--amber); }
.tbl .bad-text { color: var(--red); }

/* ---- BAR CHART ---- */
.bars { margin: 4px 0; }
.bar-r { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
.bar-l { font-size: 10px; color: var(--text); min-width: 90px; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bar-t { flex: 1; height: 12px; background: var(--faint); }
.bar-f { height: 100%; background: linear-gradient(90deg, var(--blue), var(--cyan)); transition: width 0.4s ease; }
.bar-v { font-size: 9px; color: var(--dim); min-width: 28px; }

/* ---- LISTS ---- */
.lst { list-style: none; }
.lst li { padding: 3px 0; font-size: 11px; line-height: 1.6; }
.lst li::before { content: "\203A "; color: var(--cyan); font-weight: 700; margin-right: 4px; }

/* ---- TABS ---- */
.tab-bar { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 10px; }
.tab-btn {
  font-family: var(--font);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 6px 12px;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--dim);
  cursor: pointer;
  transition: all 0.15s;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.on { color: var(--cyan); border-bottom-color: var(--cyan); }
.tab-panel { display: none; }
.tab-panel.on { display: block; }

/* ---- 2-COL ---- */
.c2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.c3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
.sub-label { font-size: 9px; font-weight: 600; color: var(--dim); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 6px; }

/* ---- EMPTY STATE ---- */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}
.empty-t {
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--dim);
}
.empty-cursor {
  display: inline-block;
  width: 8px;
  height: 14px;
  background: var(--cyan);
  margin-left: 4px;
  animation: blink 1s step-end infinite;
}
@keyframes blink { 50% { opacity: 0; } }
.empty-sub { font-size: 11px; color: var(--faint); margin-top: 6px; }

/* ---- MODAL ---- */
.overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(2px);
  z-index: 100;
  align-items: center;
  justify-content: center;
}
.overlay.open { display: flex; }
.modal {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 20px;
  min-width: 440px;
  max-width: 560px;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.2s ease;
}
@keyframes slideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
.modal-t { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bright); margin-bottom: 16px; }
.modal-s { font-size: 9px; font-weight: 600; color: var(--dim); text-transform: uppercase; letter-spacing: 0.12em; margin: 12px 0 6px; }
.modal-row { display: flex; gap: 8px; }
.m-input {
  flex: 1;
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: var(--font);
  font-size: 11px;
  padding: 6px 8px;
  outline: none;
  transition: border-color 0.15s;
}
.m-input:focus { border-color: var(--cyan); }
.m-input-lbl { font-size: 9px; color: var(--dim); margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.08em; }
.modal-check { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text); cursor: pointer; margin: 3px 0; }
.modal-check input { accent-color: var(--cyan); }

.export-opts { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 8px 0; }
.ex-card {
  border: 1px solid var(--border);
  padding: 14px 10px;
  text-align: center;
  cursor: pointer;
  transition: all 0.15s;
}
.ex-card:hover { border-color: var(--cyan); background: rgba(0,212,255,0.03); }
.ex-icon { font-size: 20px; margin-bottom: 4px; }
.ex-title { font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--bright); }
.ex-desc { font-size: 9px; color: var(--dim); margin-top: 3px; }

.modal-btns { display: flex; gap: 6px; margin-top: 14px; }
.modal-btns .s-btn { flex: 1; }

/* ---- ANIMATIONS ---- */
@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
.fade { animation: fadeSlideIn 0.35s ease forwards; }
.fd1 { animation-delay: 0.06s; opacity: 0; }
.fd2 { animation-delay: 0.14s; opacity: 0; }
.fd3 { animation-delay: 0.22s; opacity: 0; }

/* Stagger each widget */
.w { opacity: 0; animation: fadeSlideIn 0.3s ease forwards; }
.w:nth-child(1) { animation-delay: 0.24s; }
.w:nth-child(2) { animation-delay: 0.30s; }
.w:nth-child(3) { animation-delay: 0.36s; }
.w:nth-child(4) { animation-delay: 0.42s; }
.w:nth-child(5) { animation-delay: 0.48s; }
.w:nth-child(6) { animation-delay: 0.54s; }
.w:nth-child(7) { animation-delay: 0.60s; }

/* Stagger metric cards */
.m-card { opacity: 0; animation: fadeSlideIn 0.25s ease forwards; }
.m-card:nth-child(1) { animation-delay: 0.08s; }
.m-card:nth-child(2) { animation-delay: 0.12s; }
.m-card:nth-child(3) { animation-delay: 0.16s; }
.m-card:nth-child(4) { animation-delay: 0.20s; }
.m-card:nth-child(5) { animation-delay: 0.24s; }
.m-card:nth-child(6) { animation-delay: 0.28s; }
.m-card:nth-child(7) { animation-delay: 0.32s; }
.m-card:nth-child(8) { animation-delay: 0.36s; }
.m-card:nth-child(9) { animation-delay: 0.40s; }

/* Ambient line at top of main area */
.main::before {
  content: "";
  display: block;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan), transparent);
  opacity: 0.15;
  margin-bottom: 16px;
}
</style>
</head>
<body>
<div class="app">

  <!-- ======== SIDEBAR ======== -->
  <div class="side">
    <div class="brand">
      <span class="brand-mark">HD</span>
      <span class="brand-name">KASEYA<br><b>HELP DESK</b>SERVICES</span>
    </div>

    <div class="drop {{ 'loaded' if csv_name else '' }}" id="dropZone">
      <input type="file" accept=".csv" id="csvIn">
      {% if csv_name %}
        <div class="drop-file">{{ csv_name }}</div>
        <div class="drop-text">drop to replace</div>
      {% else %}
        <div class="drop-icon">+</div>
        <div class="drop-text">drop csv or click</div>
      {% endif %}
    </div>

    <div class="mode-label">mode</div>
    <div class="mode-row">
      <button class="mode-btn {{ 'on' if mode == MODE_CUSTOMER else '' }}" onclick="setMode('{{ MODE_CUSTOMER }}')">PARTNER</button>
      <button class="mode-btn {{ 'on' if mode == MODE_INTERNAL else '' }}" onclick="setMode('{{ MODE_INTERNAL }}')">INTERNAL</button>
    </div>

    <div class="spacer"></div>

    <div class="side-actions">
      <button class="s-btn pri" onclick="openExport()" {{ 'disabled' if not has_data else '' }}>EXPORT</button>
      <button class="s-btn" onclick="openSettings()">SETTINGS</button>
    </div>
  </div>

  <!-- ======== MAIN ======== -->
  <div class="main">

    <div class="head fade">
      <div class="head-title">{{ app_name }}</div>
      <div class="head-meta">
        {% if mode == MODE_INTERNAL %}<span class="tag hi">INTERNAL</span>{% else %}<span class="tag hi">PARTNER</span>{% endif %}
        {% if partner_name %}<span class="tag">{{ partner_name }}</span>{% endif %}
        {% if date_range %}<span class="tag">{{ date_range }}</span>{% endif %}
      </div>
    </div>

    {% if error %}
    <div style="border-left:3px solid var(--red);padding:8px 12px;color:var(--red);margin-bottom:12px;">{{ error }}</div>
    {% endif %}

    {% if not has_data %}
    <div class="empty">
      <div class="empty-t">upload a ticket csv to begin<span class="empty-cursor"></span></div>
      <div class="empty-sub">drop a file in the sidebar to start</div>
    </div>

    {% else %}
    <!-- METRICS -->
    <div class="grid-9 fade fd1">
      {% for label, value in a.headline_metrics[:9] %}
      <div class="m-card" data-metric="{{ label }}">
        <div class="m-label">{{ label }}</div>
        <div class="m-val" data-val="{{ value }}">{{ value }}</div>
        <svg class="m-spark-svg" data-label="{{ label }}" width="60" height="24"></svg>
        <div class="m-tooltip"></div>
      </div>
      {% endfor %}
    </div>

    <div class="inquiry fade fd2">what do you want to know?</div>

    <!-- WIDGETS -->
    <div class="fade fd3">

    <!-- Executive Brief -->
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot"></span>Executive Brief</span>
        <span><span class="w-badge">{{ a.executive_brief_points|length }} points</span><span class="w-arrow">&#9656;</span></span>
      </div>
      <div class="w-body"><div class="w-inner">
        <div class="c2">
          <div>
            <div class="sub-label">Summary</div>
            <ul class="lst">{% for p in a.executive_brief_points %}<li>{{ p }}</li>{% endfor %}</ul>
          </div>
          <div>
            <div class="sub-label">Review Topics</div>
            <ul class="lst">{% for p in a.priority_actions[:5] %}<li>{{ p }}</li>{% endfor %}</ul>
          </div>
        </div>
      </div></div>
    </div>

    <!-- Resolution Time -->
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot"></span>Resolution Time</span>
        <span><span class="w-badge">median {{ a.resolution.median_fmt }} &middot; p90 {{ a.resolution.p90_fmt }}</span><span class="w-arrow">&#9656;</span></span>
      </div>
      <div class="w-body"><div class="w-inner">
        <div class="c3" style="margin-bottom:10px;">
          <div style="text-align:center;"><div class="sub-label">Median</div><div style="font-size:18px;font-weight:700;color:var(--bright);">{{ a.resolution.median_fmt }}</div></div>
          <div style="text-align:center;"><div class="sub-label">P90</div><div style="font-size:18px;font-weight:700;color:var(--bright);">{{ a.resolution.p90_fmt }}</div></div>
          <div style="text-align:center;"><div class="sub-label">P95</div><div style="font-size:18px;font-weight:700;color:var(--bright);">{{ a.resolution.p95_fmt }}</div></div>
        </div>
        <div class="tab-bar">
          <button class="tab-btn on" onclick="switchTab(this,'res')">By Queue</button>
          <button class="tab-btn" onclick="switchTab(this,'res')">By Priority</button>
          <button class="tab-btn" onclick="switchTab(this,'res')">By Issue Type</button>
        </div>
        <div class="tab-panel on" data-tabs="res">
          {% if a.resolution.by_queue %}
          <table class="tbl"><tr><th>Queue</th><th class="r">Tickets</th><th class="r">Median</th><th class="r">P90</th></tr>
          {% for r in a.resolution.by_queue[:8] %}<tr><td>{{ r.Queue }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r['Median (min)'] }}m</td><td class="r">{{ r['P90 (min)'] }}m</td></tr>{% endfor %}
          </table>{% else %}<div style="color:var(--dim)">No data</div>{% endif %}
        </div>
        <div class="tab-panel" data-tabs="res">
          {% if a.resolution.by_priority %}
          <table class="tbl"><tr><th>Priority</th><th class="r">Tickets</th><th class="r">Median</th><th class="r">P90</th></tr>
          {% for r in a.resolution.by_priority[:8] %}<tr><td>{{ r.Priority }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r['Median (min)'] }}m</td><td class="r">{{ r['P90 (min)'] }}m</td></tr>{% endfor %}
          </table>{% else %}<div style="color:var(--dim)">No data</div>{% endif %}
        </div>
        <div class="tab-panel" data-tabs="res">
          {% if a.resolution.by_issue_type %}
          <table class="tbl"><tr><th>Issue Type</th><th class="r">Tickets</th><th class="r">Median</th><th class="r">P90</th></tr>
          {% for r in a.resolution.by_issue_type[:8] %}<tr><td>{{ r['Issue Type'] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r['Median (min)'] }}m</td><td class="r">{{ r['P90 (min)'] }}m</td></tr>{% endfor %}
          </table>{% else %}<div style="color:var(--dim)">No data</div>{% endif %}
        </div>
      </div></div>
    </div>

    <!-- SLA Compliance -->
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot"></span>SLA Compliance</span>
        <span><span class="w-badge accent" style="color:{% if a.sla.overall >= 90 %}var(--green){% elif a.sla.overall >= 75 %}var(--amber){% else %}var(--red){% endif %}">{{ a.sla.overall }}%</span><span class="w-arrow">&#9656;</span></span>
      </div>
      <div class="w-body"><div class="w-inner">
        <div class="tab-bar">
          <button class="tab-btn on" onclick="switchTab(this,'sla')">By Priority</button>
          <button class="tab-btn" onclick="switchTab(this,'sla')">Breaches</button>
        </div>
        <div class="tab-panel on" data-tabs="sla">
          {% if a.sla.by_priority %}
          <table class="tbl">
            <tr><th>Priority</th><th class="r">Tickets</th><th class="r">Target</th><th class="r">Compliance</th></tr>
            {% for r in a.sla.by_priority %}
            <tr>
              <td>{{ r.Priority }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r['Target (min)'] }}m</td>
              <td class="r {% if r.Compliance >= 95 %}accent{% elif r.Compliance < 80 %}bad-text{% endif %}">{{ r.Compliance }}%</td>
            </tr>
            {% endfor %}
          </table>
          {% else %}<div style="color:var(--dim)">No SLA data</div>{% endif %}
        </div>
        <div class="tab-panel" data-tabs="sla">
          {% if a.sla.breach_count > 0 %}
          <div style="font-size:10px;color:var(--red);margin-bottom:6px;">{{ a.sla.breach_count }} tickets breaching SLA targets</div>
          <table class="tbl"><tr><th>Ticket</th><th>Priority</th><th class="r">Resolution</th><th class="r">Target</th></tr>
          {% for r in a.sla.breaching[:10] %}
          <tr><td>{{ r.get('Ticket Number','—') }}</td><td>{{ r.Priority }}</td><td class="r bad-text">{{ r['Resolution Minutes']|round|int }}m</td><td class="r">{{ r['SLA Target (min)']|round|int }}m</td></tr>
          {% endfor %}
          </table>
          {% else %}<div style="color:var(--green);font-size:11px;">All tickets within SLA targets</div>{% endif %}
        </div>
      </div></div>
    </div>

    <!-- Queue & Escalation -->
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot"></span>Queue & Escalation</span>
        <span>
          <span class="w-badge">{{ a.queue_table|length }} queues &middot; {{ a.escalation_table|length }} reasons</span>
          <span class="w-mini">{% for r in a.queue_table[:6] %}<span class="w-mini-bar" style="height:{{ (r.Share / 100 * 12)|round|int }}px"></span>{% endfor %}</span>
          <span class="w-arrow">&#9656;</span>
        </span>
      </div>
      <div class="w-body"><div class="w-inner">
        <div class="tab-bar">
          <button class="tab-btn on" onclick="switchTab(this,'qe')">Queues</button>
          <button class="tab-btn" onclick="switchTab(this,'qe')">Escalation Reasons</button>
          <button class="tab-btn" onclick="switchTab(this,'qe')">Categories</button>
          <button class="tab-btn" onclick="switchTab(this,'qe')">Sources</button>
        </div>
        <div class="tab-panel on" data-tabs="qe">
          <div class="bars">
            {% for r in a.queue_table[:8] %}
            <div class="bar-r"><div class="bar-l">{{ r.Queue[:22] }}</div><div class="bar-t"><div class="bar-f" style="width:{{ r.Share }}%"></div></div><div class="bar-v">{{ r.Tickets }}</div></div>
            {% endfor %}
          </div>
        </div>
        <div class="tab-panel" data-tabs="qe">
          <div class="bars">
            {% for r in a.escalation_table[:8] %}
            <div class="bar-r"><div class="bar-l">{{ r['Escalation Reason'][:22] }}</div><div class="bar-t"><div class="bar-f" style="width:{{ r.Share }}%"></div></div><div class="bar-v">{{ r.Tickets }}</div></div>
            {% endfor %}
          </div>
        </div>
        <div class="tab-panel" data-tabs="qe">
          {% if a.escalation_category_table %}
          <table class="tbl"><tr><th>Category</th><th>Reason</th><th class="r">Tix</th><th class="r">%</th></tr>
          {% for r in a.escalation_category_table[:10] %}<tr><td>{{ r.Category }}</td><td>{{ r['Escalation Reason'][:20] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r.Share }}%</td></tr>{% endfor %}
          </table>{% else %}<div style="color:var(--dim)">No category data</div>{% endif %}
        </div>
        <div class="tab-panel" data-tabs="qe">
          {% if a.source_table %}
          <div class="bars">
            {% for r in a.source_table[:6] %}
            <div class="bar-r"><div class="bar-l">{{ r.Source[:18] }}</div><div class="bar-t"><div class="bar-f" style="width:{{ r.Share }}%"></div></div><div class="bar-v">{{ r.Tickets }}</div></div>
            {% endfor %}
          </div>{% else %}<div style="color:var(--dim)">No source data</div>{% endif %}
        </div>
      </div></div>
    </div>

    <!-- Coverage -->
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot"></span>Coverage</span>
        <span><span class="w-badge">{{ a.company_table|length }} accounts &middot; {{ a.issue_type_table|length }} types</span><span class="w-arrow">&#9656;</span></span>
      </div>
      <div class="w-body"><div class="w-inner">
        <div class="tab-bar">
          <button class="tab-btn on" onclick="switchTab(this,'cov')">Accounts</button>
          <button class="tab-btn" onclick="switchTab(this,'cov')">Issue Types</button>
          <button class="tab-btn" onclick="switchTab(this,'cov')">Sub-Issue Types</button>
        </div>
        <div class="tab-panel on" data-tabs="cov">
          <table class="tbl"><tr><th>Company</th><th class="r">Tix</th><th class="r">%</th></tr>
          {% for r in a.company_table[:10] %}<tr><td>{{ r.Company[:32] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r.Share }}%</td></tr>{% endfor %}
          </table>
        </div>
        <div class="tab-panel" data-tabs="cov">
          <table class="tbl"><tr><th>Type</th><th class="r">Tix</th><th class="r">%</th></tr>
          {% for r in a.issue_type_table[:10] %}<tr><td>{{ r['Issue Type'][:28] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r.Share }}%</td></tr>{% endfor %}
          </table>
        </div>
        <div class="tab-panel" data-tabs="cov">
          {% if a.sub_issue_type_table %}
          <table class="tbl"><tr><th>Sub-Type</th><th class="r">Tix</th><th class="r">%</th></tr>
          {% for r in a.sub_issue_type_table[:10] %}<tr><td>{{ r['Sub-Issue Type'][:28] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r.Share }}%</td></tr>{% endfor %}
          </table>{% else %}<div style="color:var(--dim)">No sub-issue data</div>{% endif %}
        </div>
      </div></div>
    </div>

    <!-- Danger Zone -->
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot warn"></span>Danger Zone</span>
        <span><span class="w-badge">{{ a.repeat_contacts|length }} repeats &middot; {{ a.after_hours.rate }}% after-hrs</span><span class="w-arrow">&#9656;</span></span>
      </div>
      <div class="w-body"><div class="w-inner">
        <div class="tab-bar">
          <button class="tab-btn on" onclick="switchTab(this,'dz')">Repeat Contacts</button>
          <button class="tab-btn" onclick="switchTab(this,'dz')">Hot Companies</button>
          <button class="tab-btn" onclick="switchTab(this,'dz')">After Hours</button>
        </div>
        <div class="tab-panel on" data-tabs="dz">
          {% if a.repeat_contacts %}
          <table class="tbl"><tr><th>Contact</th><th class="r">Tix</th><th>Companies</th></tr>
          {% for r in a.repeat_contacts[:10] %}<tr><td>{{ r.Contact[:22] }}</td><td class="r warn-text">{{ r.Tickets }}</td><td style="font-size:9px;color:var(--dim);">{{ r.Companies[:30] }}</td></tr>{% endfor %}
          </table>
          {% else %}<div style="color:var(--dim)">None above threshold</div>{% endif %}
        </div>
        <div class="tab-panel" data-tabs="dz">
          {% if a.danger_zone_companies %}
          <table class="tbl"><tr><th>Company</th><th class="r">Tix</th><th class="r">Esc</th><th class="r">Esc%</th></tr>
          {% for r in a.danger_zone_companies[:10] %}
          <tr><td>{{ r.Company[:26] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r.Escalated }}</td>
          <td class="r {% if r['Escalation Rate'] >= 80 %}bad-text{% elif r['Escalation Rate'] >= 50 %}warn-text{% endif %}">{{ r['Escalation Rate'] }}%</td></tr>
          {% endfor %}
          </table>
          {% else %}<div style="color:var(--dim)">No data</div>{% endif %}
        </div>
        <div class="tab-panel" data-tabs="dz">
          <div class="c3" style="margin-bottom:8px;">
            <div style="text-align:center;"><div class="sub-label">Total After-Hours</div><div style="font-size:18px;font-weight:700;color:var(--bright);">{{ a.after_hours.total }}</div><div style="font-size:9px;color:var(--dim);">{{ a.after_hours.rate }}%</div></div>
            <div style="text-align:center;"><div class="sub-label">Weekend</div><div style="font-size:18px;font-weight:700;color:var(--bright);">{{ a.after_hours.weekend }}</div></div>
            <div style="text-align:center;"><div class="sub-label">Evening</div><div style="font-size:18px;font-weight:700;color:var(--bright);">{{ a.after_hours.weekday_ah }}</div></div>
          </div>
          <div style="margin-top:8px;"><div class="sub-label">FCR Rate</div><div style="font-size:18px;font-weight:700;color:var(--cyan);">{{ a.fcr_rate }}%</div></div>
          {% if a.after_hours.by_day %}
          <div style="margin-top:10px;" class="bars">
            {% set max_day = namespace(v=1) %}{% for d in a.after_hours.by_day %}{% if d.Tickets > max_day.v %}{% set max_day.v = d.Tickets %}{% endif %}{% endfor %}
            {% for d in a.after_hours.by_day %}
            <div class="bar-r"><div class="bar-l">{{ d.Day[:3] }}</div><div class="bar-t"><div class="bar-f" style="width:{{ (d.Tickets / max_day.v * 100)|round }}%"></div></div><div class="bar-v">{{ d.Tickets }}</div></div>
            {% endfor %}
          </div>{% endif %}
        </div>
      </div></div>
    </div>

    <!-- Technicians (Internal) -->
    {% if mode == MODE_INTERNAL %}
    <div class="w">
      <div class="w-head" onclick="toggle(this)">
        <span class="w-title"><span class="dot bad"></span>Technicians</span>
        <span><span class="w-badge">internal only</span><span class="w-arrow">&#9656;</span></span>
      </div>
      <div class="w-body"><div class="w-inner">
        {% if a.technician_scorecards %}
        <table class="tbl">
          <tr><th>Technician</th><th class="r">Tix</th><th class="r">Avg Res</th><th class="r">Esc%</th><th class="r">FCR%</th></tr>
          {% for r in a.technician_scorecards[:12] %}
          <tr>
            <td>{{ r.Technician[:20] }}</td><td class="r">{{ r.Tickets }}</td><td class="r">{{ r['Avg Resolution (min)'] }}m</td>
            <td class="r {% if r['Escalation Rate'] > 60 %}bad-text{% elif r['Escalation Rate'] > 40 %}warn-text{% endif %}">{{ r['Escalation Rate'] }}%</td>
            <td class="r">{{ r.get('FCR Rate', '—') }}%</td>
          </tr>
          {% endfor %}
        </table>
        {% endif %}
        {% if a.noise.total > 0 %}
        <div style="margin-top:10px;font-size:10px;color:var(--dim);">Noise: {{ a.noise.total }} ({{ a.noise.rate }}%) — Spam {{ a.noise.spam }} &middot; Sync {{ a.noise.sync }}</div>
        {% endif %}
      </div></div>
    </div>
    {% endif %}

    </div><!-- end fade fd3 -->
    {% endif %}

  </div>
</div>

<!-- EXPORT MODAL -->
<div class="overlay" id="exportModal">
  <div class="modal">
    <div class="modal-t">Export Report</div>
    <div class="modal-s">Report Details</div>
    <div class="modal-row">
      <div style="flex:1"><div class="m-input-lbl">Title</div><input class="m-input" id="exTitle" value="{{ report_title }}"></div>
      <div style="flex:1"><div class="m-input-lbl">Filename</div><input class="m-input" id="exFile" value="{{ output_filename }}"></div>
    </div>
    <div class="modal-s">Format</div>
    <div class="export-opts">
      <div class="ex-card" onclick="doExport('wb')">
        <div class="ex-icon">&#9776;</div>
        <div class="ex-title">Workbook</div>
        <div class="ex-desc">Excel with summary, tickets, escalations</div>
      </div>
      <div class="ex-card" onclick="doExport('both')">
        <div class="ex-icon">&#9776;+&#9724;</div>
        <div class="ex-title">Workbook + PDF</div>
        <div class="ex-desc">Full workbook + executive snapshot</div>
      </div>
    </div>
    <button class="s-btn" onclick="closeModal('exportModal')" style="width:100%;margin-top:8px;">CLOSE</button>
  </div>
</div>

<!-- SETTINGS MODAL -->
<div class="overlay" id="settingsModal">
  <div class="modal">
    <div class="modal-t">Settings</div>
    <div class="modal-s">SLA Targets (minutes)</div>
    <div class="modal-row">
      {% for p in ['Critical','High','Medium','Low','None'] %}
      <div><div class="m-input-lbl">{{ p }}</div><input class="m-input sla-in" data-p="{{ p }}" type="number" value="{{ settings.sla_targets.get(p, 1440) }}" style="width:68px;"></div>
      {% endfor %}
    </div>
    <div class="modal-s">Noise Filtering</div>
    <label class="modal-check"><input type="checkbox" id="chkSpam" {{ 'checked' if settings.noise_filter.get('hide_spam', True) }}>Hide spam</label>
    <label class="modal-check"><input type="checkbox" id="chkSync" {{ 'checked' if settings.noise_filter.get('hide_sync_errors', True) }}>Hide sync errors</label>
    <div class="modal-s">About</div>
    <div style="font-size:10px;color:var(--dim);">{{ app_name }} v{{ app_version }} &middot; local-only</div>
    <div class="modal-btns">
      <button class="s-btn pri" onclick="saveSettings()">SAVE</button>
      <button class="s-btn" onclick="resetSettings()">RESET</button>
      <button class="s-btn" onclick="closeModal('settingsModal')">CLOSE</button>
    </div>
  </div>
</div>

<script>
function toggle(h){
  h.classList.toggle('open');
  h.nextElementSibling.classList.toggle('open');
  h.closest('.w').classList.toggle('active');
}

function switchTab(btn, group) {
  // Deactivate siblings in the tab bar
  btn.parentElement.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  // Find the index of this button
  const idx = Array.from(btn.parentElement.children).indexOf(btn);
  // Show matching panel, hide others
  const panels = btn.closest('.w-inner').querySelectorAll('.tab-panel[data-tabs="'+group+'"]');
  panels.forEach((p, i) => { p.classList.toggle('on', i === idx); });
}
function openExport(){document.getElementById('exportModal').classList.add('open')}
function openSettings(){document.getElementById('settingsModal').classList.add('open')}
function closeModal(id){document.getElementById(id).classList.remove('open')}
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open')}));

document.getElementById('csvIn').addEventListener('change',async e=>{
  const f=e.target.files[0];if(!f)return;
  const fd=new FormData();fd.append('file',f);
  const r=await fetch('/upload',{method:'POST',body:fd});
  if(r.ok)location.reload();else alert('Upload failed');
});

async function setMode(m){await fetch('/mode/'+m,{method:'POST'});location.reload()}

function doExport(t){
  window.open('/export/workbook','_blank');
  if(t==='both')setTimeout(()=>window.open('/export/pdf','_blank'),400);
  closeModal('exportModal');
}

async function saveSettings(){
  const sla={};document.querySelectorAll('.sla-in').forEach(i=>sla[i.dataset.p]=parseInt(i.value)||1440);
  await fetch('/settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
    sla_targets:sla,noise_filter:{hide_spam:document.getElementById('chkSpam').checked,hide_sync_errors:document.getElementById('chkSync').checked}
  })});location.reload();
}
async function resetSettings(){await fetch('/settings/reset',{method:'POST'});location.reload()}

// ---- SPARKLINE DATA ----
const SPARKS = {{ a.get('sparks', {}) | tojson }};

// Render SVG sparklines per metric card
document.querySelectorAll('.m-spark-svg').forEach(svg => {
  const label = svg.dataset.label;
  const data = SPARKS[label];
  if (!data || !data.length) { svg.style.display = 'none'; return; }

  const w = 60, h = 24, gap = 1;
  const mx = Math.max(...data, 1);
  const barW = Math.max(2, (w - gap * (data.length - 1)) / data.length);

  data.forEach((v, i) => {
    const barH = Math.max(1, (v / mx) * (h - 2));
    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('x', i * (barW + gap));
    rect.setAttribute('y', h - barH);
    rect.setAttribute('width', barW);
    rect.setAttribute('height', barH);
    rect.setAttribute('fill', '#00d4ff');
    rect.setAttribute('rx', '0.5');
    // Animate from 0
    rect.style.transform = `scaleY(0)`;
    rect.style.transformOrigin = 'bottom';
    rect.style.transition = `transform 0.4s ease ${i * 0.04 + 0.3}s`;
    svg.appendChild(rect);
    requestAnimationFrame(() => requestAnimationFrame(() => { rect.style.transform = 'scaleY(1)'; }));
  });

  // Tooltip on hover showing data
  const card = svg.closest('.m-card');
  const tip = card.querySelector('.m-tooltip');
  if (tip) {
    const total = data.reduce((a,b) => a+b, 0);
    tip.textContent = data.map(v => typeof v === 'number' ? (v % 1 ? v.toFixed(1) : v) : v).join(' · ');
  }
});

// Animate bar fills on load
document.querySelectorAll('.bar-f').forEach(b => {
  const w = b.style.width;
  b.style.width = '0';
  requestAnimationFrame(() => requestAnimationFrame(() => { b.style.width = w; }));
});

// Count-up animation for metric values
document.querySelectorAll('.m-val').forEach(el => {
  const raw = el.textContent.trim();
  const num = parseFloat(raw.replace(/[^0-9.]/g, ''));
  if (isNaN(num) || num === 0) return;
  const suffix = raw.replace(/[0-9.,]+/, '');
  const isInt = !raw.includes('.') || raw.endsWith('%');
  const duration = 700;
  const start = performance.now();
  el.textContent = isInt ? '0' + suffix : '0.0' + suffix;
  function step(now) {
    const p = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    const val = num * ease;
    el.textContent = (isInt ? Math.round(val) : val.toFixed(1)) + suffix;
    if (p < 1) requestAnimationFrame(step);
  }
  const idx = el.closest('.m-card') ? Array.from(el.closest('.grid-9').children).indexOf(el.closest('.m-card')) : 0;
  setTimeout(() => requestAnimationFrame(step), idx * 70 + 200);
});
</script>
</body>
</html>
